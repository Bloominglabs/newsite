    "content": "\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Solar Panel & Battery Sizing Calculator</title>\n    <style>\n        body { font-family: Arial, sans-serif; max-width: 800px; margin: 20px auto; padding: 20px; }\n        h1 { text-align: center; }\n        label { display: block; margin: 10px 0 5px; }\n        input, button { padding: 8px; width: 100%; box-sizing: border-box; }\n        button { background: #007bff; color: white; border: none; cursor: pointer; margin-top: 20px; }\n        #results { margin-top: 30px; padding: 15px; background: #f8f9fa; border: 1px solid #ddd; }\n        .note { font-size: 0.9em; color: #555; }\n    </style>\n</head>\n<body>\n    <h1>Solar Panel & Li-ion Battery Sizing Calculator (24/7 Operation)</h1>\n    <p>Inputs current draw and latitude to recommend a solar panel and rechargeable Li-ion battery for reliable off-grid operation.</p>\n\n    <label for=\"mA\">Current draw (mA):</label>\n    <input type=\"number\" id=\"mA\" value=\"100\" min=\"1\">\n\n    <label for=\"latitude\">Latitude (degrees, e.g., 45 or -33 for southern hemisphere):</label>\n    <input type=\"number\" id=\"latitude\" value=\"40\" step=\"0.1\">\n\n    <button onclick=\"calculate()\">Calculate</button>\n\n    <div id=\"results\"></div>\n\n    <p class=\"note\">\n        Assumptions: 3.7V Li-ion system • 30% safety margin • 2 days autonomy • Conservative worst-month PSH.<br>\n        For precise PSH, use tools like Global Solar Atlas.\n    </p>\n\n    <script>\n        function calculate() {\n            const mA = parseFloat(document.getElementById('mA').value);\n            const latInput = parseFloat(document.getElementById('latitude').value);\n            if (isNaN(mA) || isNaN(latInput) || mA <= 0) {\n                document.getElementById('results').innerHTML = '<p style=\"color:red;\">Please enter valid positive numbers.</p>';\n                return;\n            }\n\n            const absLat = Math.abs(latInput);\n            let PSH;\n            if (absLat < 15) PSH = 5.0;\n            else if (absLat < 30) PSH = 4.5;\n            else if (absLat < 40) PSH = 4.0;\n            else if (absLat < 50) PSH = 3.5;\n            else if (absLat < 60) PSH = 3.0;\n            else PSH = 2.5;\n\n            const V = 3.7;\n            const safety = 1.3;\n            const autonomy = 2;\n\n            const powerW = (mA / 1000) * V;\n            const dailyWh = powerW * 24;\n            const panelW = (dailyWh / PSH) * safety;\n            const batteryMah = (dailyWh / V) * 1000 * autonomy;\n\n            const panelRounded = Math.ceil(panelW);\n            const batteryRounded = Math.ceil(batteryMah / 1000) * 1000; // Next 1000 mAh\n\n            const results = `\n                <h2>Results</h2>\n                <p><strong>Current draw:</strong> ${mA} mA</p>\n                <p><strong>Latitude:</strong> ${latInput}° (estimated conservative PSH: ${PSH} hours/day)</p>\n                <p><strong>Daily energy consumption:</strong> ${dailyWh.toFixed(2)} Wh</p>\n                <p><strong>Recommended solar panel:</strong> ${panelW.toFixed(1)} W<br>\n                → Choose at least a <strong>${panelRounded} W</strong> panel (or next common size, add 20-50% margin in cloudy areas)</p>\n                <p><strong>Recommended Li-ion battery:</strong> ${batteryMah.toFixed(0)} mAh<br>\n                → Choose at least <strong>${batteryRounded} mAh</strong> (e.g., multiple 18650 cells)</p>\n                <p class=\"note\">This is conservative for 24/7 reliability. Oversize for variable weather.</p>\n            `;\n\n            document.getElementById('results').innerHTML = results;\n        }\n\n        // Run on load with defaults\n        window.onload = calculate;\n    </script>\n</body>\n</html>"
  }
